---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import About from '../components/About.astro';
import ProjectsHeader from '../components/ProjectsHeader.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';

import projects from '../data/projects.json';
---

<BaseLayout>
  <Nav />

  <div class="page-wrap">
    <About />
    <ProjectsHeader count={projects.length} />

    <div class="project-grid">
      {projects.map((project, i) => (
        <ProjectCard
          project={project}
          index={i + 1}
          total={projects.length}
          featured={i === 0}
        />
      ))}
    </div>
  </div>

  <Footer />
<!-- Lightbox overlay -->
<div id="lightbox" aria-hidden="true">
  <button id="lightbox-close" aria-label="Close">&#x2715;</button>
  <img id="lightbox-img" src="" alt="" />
</div>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {

    // ── Title badge cycling ──────────────────────────────
    var tagData = [
      {
        text: 'Full Stack Engineer',
        icon: '<svg class="tag-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>'
      },
      {
        text: 'AI &amp; Agent Builder',
        icon: '<svg class="tag-icon" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.09 6.26L21 10l-6.91 1.74L12 18l-2.09-6.26L3 10l6.91-1.74L12 2z"/><circle cx="5" cy="5" r="1.5"/><circle cx="19" cy="19" r="1"/></svg>'
      },
      {
        text: '5 Yrs &middot; Production',
        icon: '<svg class="tag-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>'
      }
    ];
    var tagIdx   = 0;
    var tagBadge = document.querySelector('.title-tag');
    var tagWord  = document.querySelector('.tag-word');

    if (tagBadge && tagWord) {
      setInterval(function() {
        tagWord.classList.add('exit');
        tagBadge.classList.add('flash');

        setTimeout(function() {
          tagIdx = (tagIdx + 1) % tagData.length;
          tagWord.innerHTML = tagData[tagIdx].icon + tagData[tagIdx].text;
          tagWord.classList.remove('exit');
          tagWord.classList.add('enter');

          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              tagWord.classList.remove('enter');
              setTimeout(function() { tagBadge.classList.remove('flash'); }, 300);
            });
          });
        }, 230);
      }, 2600);
    }

    // ── Scroll-reveal for .reveal elements ──────────────
    var revealObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          // stagger by DOM index among sibling .reveal elements
          var siblings = Array.from(el.parentElement.querySelectorAll('.reveal'));
          var idx = siblings.indexOf(el);
          el.style.transitionDelay = (idx * 0.09) + 's';
          el.classList.add('visible');
          revealObserver.unobserve(el);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(function(el) {
      revealObserver.observe(el);
    });

    // ── Screenshot sliders ───────────────────────────────
    document.querySelectorAll('.ss-wrap').forEach(function(wrap) {
      var track  = wrap.querySelector('.ss-track');
      var dots   = wrap.querySelectorAll('.ss-dot');
      var slides = wrap.querySelectorAll('.ss-slide');
      var total  = slides.length;
      var current = 0;

      function goTo(index) {
        current = (index + total) % total;
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        dots.forEach(function(d, i) {
          d.classList.toggle('active', i === current);
        });
      }

      var prev = wrap.querySelector('.ss-prev');
      var next = wrap.querySelector('.ss-next');

      if (prev) prev.addEventListener('click', function(e) {
        e.stopPropagation();
        goTo(current - 1);
      });

      if (next) next.addEventListener('click', function(e) {
        e.stopPropagation();
        goTo(current + 1);
      });

      dots.forEach(function(dot, i) {
        dot.addEventListener('click', function() { goTo(i); });
      });
    });

    // ── Lightbox ─────────────────────────────────────────
    var lightbox    = document.getElementById('lightbox');
    var lightboxImg = document.getElementById('lightbox-img');
    var lightboxClose = document.getElementById('lightbox-close');

    function openLightbox(src, alt) {
      lightboxImg.src = src;
      lightboxImg.alt = alt || '';
      lightbox.classList.add('open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setTimeout(function() { lightboxImg.src = ''; }, 300);
    }

    document.querySelectorAll('.ss-slide img').forEach(function(img) {
      img.addEventListener('click', function(e) {
        e.stopPropagation();
        openLightbox(img.src, img.alt);
      });
    });

    lightboxClose.addEventListener('click', closeLightbox);

    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeLightbox();
    });

    // ── Filter chips ─────────────────────────────────────
    document.querySelectorAll('.filter-chip').forEach(function(chip) {
      chip.addEventListener('click', function() {
        document.querySelectorAll('.filter-chip').forEach(function(c) {
          c.classList.remove('active');
        });
        chip.classList.add('active');

        var filter = chip.dataset.filter;
        document.querySelectorAll('.project-card[data-category]').forEach(function(card) {
          var show = filter === 'all' || card.dataset.category === filter;
          card.style.display = show ? 'flex' : 'none';
        });
      });
    });

  });
</script>

<style>
  /* ── Lightbox ── */
  #lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  #lightbox.open {
    opacity: 1;
    pointer-events: all;
  }

  #lightbox-img {
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transform: scale(0.94);
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    display: block;
  }

  #lightbox.open #lightbox-img {
    transform: scale(1);
  }

  #lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    width: 38px;
    height: 38px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.70);
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s;
    line-height: 1;
    font-family: inherit;
    border-radius: 2px;
  }

  #lightbox-close:hover {
    background: #C9A84C;
    border-color: #C9A84C;
    color: #111;
  }
</style>
