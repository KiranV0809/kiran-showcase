---
<div class="filter">
  <span class="filter-label">Filter</span>
  <span class="chip filter-chip active" data-filter="all">All</span>
  <span class="chip filter-chip" data-filter="AI / Agents">AI / Agents</span>
  <span class="chip filter-chip" data-filter="Backend">Backend</span>
  <span class="chip filter-chip" data-filter="Full Stack">Full Stack</span>
</div>

<style>
  .filter {
    padding: 0.75rem 2.5rem;
    border-bottom: 1px solid rgba(17, 17, 17, 0.10);
    display: flex;
    gap: 0.4rem;
    align-items: center;
    background: #F8F6F1;
  }

  .filter-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(17, 17, 17, 0.28);
    margin-right: 0.5rem;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    padding: 4px 12px;
    border: 1px solid rgba(17, 17, 17, 0.15);
    color: rgba(17, 17, 17, 0.40);
    cursor: pointer;
    transition: all 0.15s;
    background: transparent;
    user-select: none;
  }

  .chip.active {
    background: #111;
    color: #F8F6F1;
    border-color: #111;
  }

  @media (max-width: 640px) {
    .filter { padding: 0.75rem 1.25rem; flex-wrap: wrap; }
  }
</style>
