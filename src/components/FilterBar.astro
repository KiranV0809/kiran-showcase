---
const chips = ['All', 'AI / Agents', 'Backend', 'Full Stack'];
---
<div class="filter-bar">
  <span class="filter-label">Filter</span>
  <div class="chips">
    {chips.map((chip, i) => (
      <button class={`chip${i === 0 ? ' active' : ''}`} data-filter={chip}>
        {chip}
      </button>
    ))}
  </div>
</div>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');

      const filter = chip.dataset.filter;

      cards.forEach(card => {
        if (filter === 'All') {
          card.style.display = '';
        } else {
          const categories = card.dataset.category || '';
          card.style.display = categories.includes(filter) ? '' : 'none';
        }
      });
    });
  });
</script>

<style>
  .filter-bar {
    display: flex;
    align-items: center;
    padding: 1rem var(--pad-page-x);
    gap: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    animation: fade-up 0.6s var(--ease-out-expo) 1.10s both;
  }

  .filter-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.20em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin-right: 0.75rem;
  }

  .chips {
    display: flex;
    gap: 0.5rem;
  }

  .chip {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(232, 224, 208, 0.28);
    text-transform: uppercase;
    background: transparent;
    border: 1px solid rgba(232, 224, 208, 0.10);
    border-radius: var(--radius-sm);
    padding: 5px 14px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s, transform 0.15s;
  }

  .chip:hover {
    border-color: var(--color-gold-dim);
    color: var(--color-gold);
    transform: translateY(-1px);
  }

  .chip.active {
    border-color: var(--color-gold);
    color: var(--color-gold);
    background: rgba(201, 168, 76, 0.06);
  }
</style>
