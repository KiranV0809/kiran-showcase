---
import ScreenshotSlider from './ScreenshotSlider.astro';

interface Tag {
  label: string;
  gold: boolean;
}

interface Slide {
  image: string;
  label: string;
}

interface Project {
  id: string;
  title: string;
  hook: string;
  description: string;
  serves: string;
  category: string;
  tags: Tag[];
  slides: Slide[];
  slideTheme: string;
}

interface Props {
  project: Project;
  index: number;
  total: number;
  featured?: boolean;
}

const { project, index, total, featured = false } = Astro.props;
---

<article
  class:list={['project-card', 'reveal', { featured }]}
  data-category={project.category}
>
  <ScreenshotSlider
    slides={project.slides}
    projectId={project.id}
    slideTheme={project.slideTheme}
  />

  <div class="card-body">
    <div class="card-top">
      {featured && <span class="featured-label">Featured Project</span>}
      <div class="card-no">{String(index).padStart(2, '0')} / {String(total).padStart(2, '0')}</div>
      <h2 class="card-title">{project.title}</h2>
      <p class="card-hook">{project.hook}</p>
    </div>

    <p class="card-desc">{project.description}</p>

    <div class="card-serves">
      <span class="serves-label">Who it's for</span>
      <span class="serves-text">{project.serves}</span>
    </div>

    <div class="card-footer">
      <div class="tech-tags">
        {project.tags.map(tag => (
          <span class={`tag${tag.gold ? ' gold' : ''}`}>{tag.label}</span>
        ))}
      </div>
    </div>
  </div>
</article>

<style>
  /* ── Base card ── */
  .project-card {
    border-right: 1px solid rgba(17, 17, 17, 0.10);
    border-bottom: 1px solid rgba(17, 17, 17, 0.10);
    background: #F8F6F1;
    display: flex;
    flex-direction: column;
    transition: background 0.25s ease,
                transform 0.25s cubic-bezier(0.16,1,0.3,1),
                box-shadow 0.25s ease,
                opacity 0.55s cubic-bezier(0.16,1,0.3,1);
  }

  .project-card:nth-child(2n) {
    border-right: none;
  }

  .project-card:last-child {
    border-bottom: none;
  }

  .project-card:hover {
    background: #FFFFFF;
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(17, 17, 17, 0.09);
    z-index: 1;
    position: relative;
  }

  /* ── Featured card ── */
  .project-card.featured {
    grid-column: 1 / -1;
    flex-direction: row;
    min-height: 400px;
    border-right: none;
    --slider-height: 100%;
  }

  /* slider fills left column */
  .project-card.featured :global(.ss-wrap) {
    width: 58%;
    flex-shrink: 0;
    border-bottom: none;
    border-right: 1px solid rgba(17, 17, 17, 0.10);
  }

  .project-card.featured .card-body {
    flex: 1;
    min-width: 0;
  }

  .project-card.featured .card-title {
    font-size: 28px;
  }

  .project-card.featured .card-desc {
    font-size: 13.5px;
  }

  /* ── Card body ── */
  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* ── Featured label ── */
  .featured-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #C9A84C;
    display: inline-block;
    margin-bottom: 0.6rem;
    padding: 3px 8px;
    border: 1px solid rgba(201, 168, 76, 0.35);
    background: rgba(201, 168, 76, 0.07);
  }

  /* ── Card top ── */
  .card-top {
    padding: 1.1rem 1.5rem 0.6rem;
  }

  .card-no {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: rgba(17, 17, 17, 0.28);
    margin-bottom: 0.3rem;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 21px;
    font-weight: 700;
    line-height: 1.15;
    color: #111;
    margin-bottom: 0.25rem;
  }

  .card-hook {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: #C9A84C;
    text-transform: uppercase;
  }

  /* ── Card desc ── */
  .card-desc {
    padding: 0 1.5rem 0.75rem;
    font-size: 12.5px;
    line-height: 1.75;
    color: rgba(17, 17, 17, 0.68);
  }

  /* ── Serves ── */
  .card-serves {
    padding: 0.75rem 1.5rem 0.9rem;
    border-top: 1px solid rgba(17, 17, 17, 0.10);
  }

  .serves-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #C9A84C;
    display: block;
    margin-bottom: 0.3rem;
  }

  .serves-text {
    font-size: 13px;
    color: rgba(17, 17, 17, 0.78);
    line-height: 1.55;
    font-weight: 500;
  }

  /* ── Footer ── */
  .card-footer {
    padding: 0.75rem 1.5rem;
    border-top: 1px solid rgba(17, 17, 17, 0.10);
    margin-top: auto;
    display: flex;
  }

  .tech-tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 9px;
    background: #111;
    color: #F8F6F1;
  }

  .tag.gold {
    background: #C9A84C;
    color: #111;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .project-card.featured {
      flex-direction: column;
      min-height: unset;
      --slider-height: 240px;
    }
    .project-card.featured :global(.ss-wrap) {
      width: 100%;
      border-right: none;
      border-bottom: 1px solid rgba(17, 17, 17, 0.10);
    }
  }
</style>
