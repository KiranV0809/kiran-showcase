---
import ScreenshotSlider from './ScreenshotSlider.astro';

interface Tag {
  label: string;
  gold: boolean;
}

interface Slide {
  image: string;
  label: string;
}

interface Project {
  id: string;
  title: string;
  hook: string;
  description: string;
  serves: string;
  category: string;
  tags: Tag[];
  slides: Slide[];
  slideTheme: string;
}

interface Props {
  project: Project;
  index: number;
  total: number;
}

const { project, index, total } = Astro.props;
---

<article
  class="project-card reveal"
  data-category={project.category}
>
  <ScreenshotSlider
    slides={project.slides}
    projectId={project.id}
    slideTheme={project.slideTheme}
  />

  <div class="card-top">
    <div class="card-no">{String(index).padStart(2, '0')} / {String(total).padStart(2, '0')}</div>
    <h2 class="card-title">{project.title}</h2>
    <p class="card-hook">{project.hook}</p>
  </div>

  <p class="card-desc">{project.description}</p>

  <div class="card-serves">
    <span class="serves-label">Serves</span>
    <span class="serves-text">{project.serves}</span>
  </div>

  <div class="card-footer">
    <div class="tech-tags">
      {project.tags.map(tag => (
        <span class={`tag${tag.gold ? ' gold' : ''}`}>{tag.label}</span>
      ))}
    </div>
  </div>
</article>

<style>
  .project-card {
    border-right: 1px solid rgba(17, 17, 17, 0.10);
    border-bottom: 1px solid rgba(17, 17, 17, 0.10);
    background: #F8F6F1;
    display: flex;
    flex-direction: column;
    transition: background 0.25s ease, transform 0.25s cubic-bezier(0.16,1,0.3,1), box-shadow 0.25s ease,
                /* inherit reveal transition */
                opacity 0.55s cubic-bezier(0.16,1,0.3,1);
  }

  .project-card:nth-child(2n) {
    border-right: none;
  }

  .project-card:last-child {
    border-bottom: none;
  }

  .project-card:hover {
    background: #FFFFFF;
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(17, 17, 17, 0.09);
    z-index: 1;
    position: relative;
  }

  .card-top {
    padding: 1.1rem 1.5rem 0.6rem;
  }

  .card-no {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: rgba(17, 17, 17, 0.28);
    margin-bottom: 0.3rem;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 21px;
    font-weight: 700;
    line-height: 1.15;
    color: #111;
    margin-bottom: 0.25rem;
  }

  .card-hook {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: #C9A84C;
    text-transform: uppercase;
  }

  .card-desc {
    padding: 0 1.5rem 0.75rem;
    font-size: 12.5px;
    line-height: 1.75;
    color: rgba(17, 17, 17, 0.68);
  }

  .card-serves {
    padding: 0 1.5rem 0.6rem;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .serves-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(17, 17, 17, 0.40);
    white-space: nowrap;
    padding-top: 2px;
  }

  .serves-text {
    font-size: 12px;
    color: rgba(17, 17, 17, 0.60);
    line-height: 1.5;
    font-style: italic;
  }

  .card-footer {
    padding: 0.75rem 1.5rem;
    border-top: 1px solid rgba(17, 17, 17, 0.07);
    margin-top: auto;
    display: flex;
  }

  .tech-tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 9px;
    background: #111;
    color: #F8F6F1;
  }

  .tag.gold {
    background: #C9A84C;
    color: #111;
  }
</style>
