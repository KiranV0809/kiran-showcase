---
interface Tag {
  label: string;
  gold: boolean;
}

interface Project {
  id: string;
  featured: boolean;
  title: string;
  oneliner: string;
  description: string;
  category: string[];
  tags: Tag[];
  github: string;
  demo: string;
  screenshot: string;
  screenshotAlt: string;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---
<section class="featured featured-reveal" id="projects">
  <!-- Left: image panel -->
  <div class="featured-img-panel">
    <div class="featured-glow" aria-hidden="true"></div>
    {project.screenshot ? (
      <img
        src={project.screenshot}
        alt={project.screenshotAlt}
        class="featured-screenshot"
      />
    ) : (
      <div class="screen-mockup">
        <div class="mac-dots">
          <span class="mac-dot red"></span>
          <span class="mac-dot yellow"></span>
          <span class="mac-dot green"></span>
        </div>
        <div class="screen-content">
          <div class="screen-line gold-line"></div>
          <div class="screen-line full-line"></div>
          <div class="screen-line full-line"></div>
          <div class="screen-line short-line"></div>
          <div class="screen-line pulse-line"></div>
          <div class="screen-line full-line"></div>
          <div class="screen-line short-line"></div>
        </div>
      </div>
    )}
  </div>

  <!-- Right: content panel -->
  <div class="featured-content">
    <div class="ghost-number" aria-hidden="true">01</div>
    <div class="featured-tag">{project.category[0]}</div>
    <h2 class="featured-title">{project.title}</h2>
    <p class="featured-oneliner">{project.oneliner}</p>
    <p class="featured-desc">{project.description}</p>

    <div class="tag-row">
      {project.tags.map(tag => (
        <span class={`tech-tag${tag.gold ? ' gold' : ''}`}>{tag.label}</span>
      ))}
    </div>

    <div class="btn-row">
      {project.github && (
        <a href={project.github} target="_blank" rel="noopener" class="btn-primary">
          View Project ↗
        </a>
      )}
      {project.github && (
        <a href={project.github} target="_blank" rel="noopener" class="btn-ghost">
          GitHub ↗
        </a>
      )}
      {project.demo && (
        <a href={project.demo} target="_blank" rel="noopener" class="btn-ghost">
          Live Demo ↗
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .featured {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    min-height: 360px;
    border-bottom: 1px solid var(--color-border);
  }

  /* Left panel */
  .featured-img-panel {
    position: relative;
    border-right: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .featured-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(201, 168, 76, 0.05), transparent);
    pointer-events: none;
    z-index: 0;
  }

  .featured-screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: relative;
    z-index: 1;
  }

  /* Decorative screen mockup */
  .screen-mockup {
    position: relative;
    width: 82%;
    height: 72%;
    border: 1px solid rgba(232, 224, 208, 0.08);
    border-radius: var(--radius-lg);
    background: var(--color-surface-3);
    z-index: 1;
    overflow: hidden;
  }

  .screen-mockup::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(201, 168, 76, 0.4), transparent);
  }

  .mac-dots {
    display: flex;
    gap: 5px;
    padding: 9px 0 0 12px;
  }

  .mac-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }

  .mac-dot.red    { background: #FF5F57; }
  .mac-dot.yellow { background: #FEBC2E; }
  .mac-dot.green  { background: #28C840; }

  .screen-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 36px 16px 16px;
  }

  .screen-line {
    height: 2px;
    border-radius: 1px;
  }

  .gold-line  { width: 45%; background: rgba(201, 168, 76, 0.25); }
  .full-line  { width: 100%; background: rgba(232, 224, 208, 0.06); }
  .short-line { width: 65%; background: rgba(232, 224, 208, 0.06); }

  .pulse-line {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(201, 168, 76, 0.5),
      transparent
    );
    background-size: 200% 100%;
    animation: shimmer 2.5s linear infinite;
  }

  /* Right panel */
  .featured-content {
    padding: 2.5rem 2.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ghost-number {
    font-family: var(--font-serif);
    font-size: 80px;
    font-weight: 300;
    letter-spacing: -0.03em;
    color: var(--color-text-ghost);
    line-height: 1;
    margin-bottom: -0.75rem;
    user-select: none;
  }

  .featured-tag {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.20em;
    color: var(--color-gold);
    text-transform: uppercase;
  }

  .featured-title {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 300;
    line-height: 1.15;
    color: var(--color-text);
  }

  .featured-oneliner {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    color: rgba(232, 224, 208, 0.28);
    text-transform: uppercase;
    padding: 6px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .featured-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.85;
    color: rgba(232, 224, 208, 0.40);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-tags);
    margin-top: 0.25rem;
  }

  .tech-tag {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.10em;
    color: rgba(232, 224, 208, 0.32);
    text-transform: uppercase;
    background: rgba(232, 224, 208, 0.04);
    border: 1px solid rgba(232, 224, 208, 0.08);
    border-radius: var(--radius-sm);
    padding: 3px 8px;
  }

  .tech-tag.gold {
    color: rgba(201, 168, 76, 0.65);
    border-color: rgba(201, 168, 76, 0.20);
    background: rgba(201, 168, 76, 0.04);
  }

  .btn-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .btn-primary {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: #080808;
    text-transform: uppercase;
    text-decoration: none;
    background: var(--color-gold);
    border: none;
    border-radius: var(--radius-sm);
    padding: 9px 18px;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s var(--ease-out-expo), box-shadow 0.2s;
    display: inline-block;
  }

  .btn-primary:hover {
    background: #D4B55E;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(201, 168, 76, 0.2);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  .btn-ghost {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(232, 224, 208, 0.32);
    text-transform: uppercase;
    text-decoration: none;
    background: transparent;
    border: 1px solid var(--color-border-md);
    border-radius: var(--radius-sm);
    padding: 9px 18px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, transform 0.2s var(--ease-out-expo);
    display: inline-block;
  }

  .btn-ghost:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
    transform: translateY(-2px);
  }
</style>
