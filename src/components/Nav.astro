---
const base = import.meta.env.BASE_URL;
---
<nav class="nav">
  <span class="nav-logo">kiranv0809<span class="dot">.</span>dev</span>

  <ul class="nav-links">
    <li>
      <a href="https://www.linkedin.com/in/saikiranvanga/" target="_blank" rel="noopener" class="nav-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
        <span class="nav-text">LinkedIn</span>
      </a>
    </li>
    <li>
      <a href="https://github.com/KiranV0809" target="_blank" rel="noopener" class="nav-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="nav-text">GitHub</span>
      </a>
    </li>
    <li>
      <a href="mailto:kiransaiv99@gmail.com" class="nav-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        <span class="nav-text">Email</span>
      </a>
    </li>
    <li>
      <a href={`${base}resume.pdf`} download class="nav-link resume-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <span class="nav-text">Resume</span>
      </a>
    </li>
  </ul>

  <div class="nav-status">
    <span class="status-dot"></span>
    <span class="status-text">Open to Work</span>
  </div>
</nav>

<style>
  .nav {
    background: #111;
    color: #F8F6F1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2.5rem;
    height: 52px;
    position: sticky;
    top: 0;
    z-index: 20;
    animation: fade-in 0.5s ease both;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    color: #F8F6F1;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo .dot {
    color: #C9A84C;
  }

  .nav-links {
    display: flex;
    gap: 1.75rem;
    list-style: none;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(248, 246, 241, 0.45);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s;
  }

  .nav-link svg {
    opacity: 0.6;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .nav-link:hover {
    color: #C9A84C;
  }

  .nav-link:hover svg {
    opacity: 1;
  }

  .resume-link {
    color: rgba(201, 168, 76, 0.70);
    border: 1px solid rgba(201, 168, 76, 0.30);
    padding: 4px 10px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .resume-link:hover {
    color: #111;
    background: #C9A84C;
    border-color: #C9A84C;
  }

  .resume-link:hover svg {
    opacity: 1;
  }

  /* Open to Work — pulse dot */
  .nav-status {
    display: flex;
    align-items: center;
    gap: 7px;
    flex-shrink: 0;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    position: relative;
    flex-shrink: 0;
  }

  .status-dot::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: rgba(74, 222, 128, 0.35);
    animation: status-pulse 2.2s ease-out infinite;
  }

  @keyframes status-pulse {
    0%   { transform: scale(1);   opacity: 1; }
    70%  { transform: scale(2.2); opacity: 0; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  .status-text {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(248, 246, 241, 0.60);
  }

  /* Mobile — icons only, keep links visible */
  @media (max-width: 640px) {
    .nav { padding: 0 1.25rem; }
    .nav-text { display: none; }
    .nav-links { gap: 1.1rem; }
    .nav-link { gap: 0; }
    .nav-link svg { opacity: 0.7; width: 16px; height: 16px; }
    .resume-link { padding: 6px; }
    .status-text { display: none; }
  }
</style>
